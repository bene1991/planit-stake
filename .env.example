# Supabase
VITE_SUPABASE_PROJECT_ID="seu_project_id"
VITE_SUPABASE_URL="https://seu_project_id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua_anon_key"

# API Football (usada via Edge Function - não expor no frontend)
# Configure no painel do Supabase em: Project Settings > Edge Functions > Secrets
# Nome da variável: API_FOOTBALL_KEY

# Telegram (usada via Edge Function - não expor no frontend)
# Configure no painel do Supabase em: Project Settings > Edge Functions > Secrets
# Variáveis: TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID (opcionais - pode usar os do banco de dados)
